# Copy this file to .env.local and fill in real values from your Firebase project
# (console.firebase.google.com -> Project settings -> General -> Your apps -> Web app).
# .env.local is gitignored (matches *.local) — never commit real keys.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
